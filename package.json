{
  "name": "@synergenius/flow-weaver-pack-weaver",
  "version": "0.9.2",
  "description": "AI bot for Flow Weaver. Execute tasks, run workflows, evolve autonomously.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node-types": {
      "types": "./dist/node-types/index.d.ts",
      "default": "./dist/node-types/index.js"
    },
    "./bot": {
      "types": "./dist/bot/index.d.ts",
      "default": "./dist/bot/index.js"
    }
  },
  "keywords": [
    "flow-weaver-marketplace-pack",
    "flow-weaver-bot-pack",
    "flow-weaver",
    "weaver",
    "automation",
    "ai-agent",
    "bot"
  ],
  "flowWeaver": {
    "type": "marketplace-pack",
    "engineVersion": ">=0.17.0",
    "categories": [
      "automation",
      "ai"
    ]
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@synergenius/flow-weaver": ">=0.21.0",
    "zod": ">=3.22.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src",
    "flowweaver.manifest.json",
    "templates.js",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/docs dist/docs && node -e \"require('fs').writeFileSync('templates.js','export{workflowTemplates}from\\\"./dist/templates/index.js\\\";\\n')\"",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "tsx scripts/release.ts",
    "dev": "npm run build && npm pack --pack-destination /tmp && echo '✓ Tarball ready at /tmp/synergenius-flow-weaver-pack-weaver-'$(node -p 'require(\"./package.json\").version')'.tgz'",
    "dev:install": "npm run dev && node -e \"const p=process.argv[1]; if(!p){console.error('Usage: npm run dev:install -- /path/to/project');process.exit(1)} require('child_process').execSync('npm install --no-save /tmp/synergenius-flow-weaver-pack-weaver-'+require('./package.json').version+'.tgz',{cwd:p,stdio:'inherit'}); console.log('✓ Installed in '+p)\" --"
  },
  "devDependencies": {
    "@synergenius/flow-weaver": "^0.22.5",
    "@types/node": "^25.3.5",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/synergenius-fw/flow-weaver-pack-weaver"
  }
}
