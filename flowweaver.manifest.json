  "eventSubscriptions": [
    {
      "event": "execution.failed",
      "handler": "dist/handlers/on-execution-failure.js",
      "functionName": "onExecutionFailure",
      "capabilities": [
        "fetch:hooks.slack.com",
        "fetch:discord.com"
      ]
    },
    {
      "event": "schedule.tick",
      "handler": "dist/handlers/scheduled-run.js",
      "functionName": "onScheduledRun",
      "schedule": "*/30 * * * *",
      "capabilities": [
        "ai:chat",
        "events:emit"
      ]
    },
    {
      "event": "bot.completed",
      "handler": "dist/handlers/on-bot-completed.js",
      "functionName": "onBotCompleted",
      "capabilities": [
        "events:emit"
      ]
    },
    {
      "event": "execution.completed",
      "handler": "dist/handlers/on-execution-completed.js",
      "functionName": "onExecutionCompleted"
    }
  ],
  "webhooks": [
    {
      "id": "task-notifications",
      "name": "Task Completion Notifications",
      "events": [
        "bot.completed",
        "execution.failed"
      ],
      "configSchema": {
        "type": "object",
        "properties": {
          "webhookUrl": {
            "type": "string",
            "description": "Webhook URL (Slack, Discord, or generic)"
          },
          "provider": {
            "type": "string",
            "enum": [
              "slack",
              "discord",
              "generic"
            ],
            "description": "Webhook provider format"
          },
          "onlyFailures": {
            "type": "boolean",
            "description": "Only send notifications on failures"
          }
        },
        "required": [
          "webhookUrl"
        ]
      }
    }
  ],
