{
  "manifestVersion": 1,
  "name": "@synergenius/flowweaver-pack-weaver",
  "version": "0.4.0",
  "description": "Autonomous workflow runner for Flow Weaver. Auto-detect providers, execute workflows, notify results.",
  "engineVersion": ">=0.17.13",
  "categories": [
    "automation",
    "ai"
  ],
  "nodeTypes": [
    {
      "name": "weaverLoadConfig",
      "description": "Read .weaver.json, merge with defaults, and output the config object.",
      "file": "dist/node-types/load-config.js",
      "functionName": "weaverLoadConfig",
      "isAsync": false,
      "inputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory (defaults to cwd)",
          "optional": true
        }
      },
      "outputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory (pass-through)"
        },
        "config": {
          "dataType": "string",
          "description": "Weaver configuration (JSON)"
        }
      }
    },
    {
      "name": "weaverDetectProvider",
      "description": "Auto-detect or resolve the configured AI provider.",
      "file": "dist/node-types/detect-provider.js",
      "functionName": "weaverDetectProvider",
      "isAsync": false,
      "inputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory"
        },
        "config": {
          "dataType": "string",
          "description": "Weaver configuration (JSON)"
        }
      },
      "outputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory (pass-through)"
        },
        "config": {
          "dataType": "string",
          "description": "Config (pass-through)"
        },
        "providerType": {
          "dataType": "string",
          "description": "Resolved provider type"
        },
        "providerInfo": {
          "dataType": "string",
          "description": "Provider details (JSON)"
        }
      }
    },
    {
      "name": "weaverResolveTarget",
      "description": "Find the target workflow file from config or by scanning the project directory.",
      "file": "dist/node-types/resolve-target.js",
      "functionName": "weaverResolveTarget",
      "isAsync": false,
      "inputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory"
        },
        "config": {
          "dataType": "string",
          "description": "Config (JSON)"
        },
        "providerType": {
          "dataType": "string",
          "description": "Provider type (pass-through)"
        },
        "providerInfo": {
          "dataType": "string",
          "description": "Provider info (pass-through)"
        }
      },
      "outputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory (pass-through)"
        },
        "config": {
          "dataType": "string",
          "description": "Config (pass-through)"
        },
        "providerType": {
          "dataType": "string",
          "description": "Provider type (pass-through)"
        },
        "providerInfo": {
          "dataType": "string",
          "description": "Provider info (pass-through)"
        },
        "targetPath": {
          "dataType": "string",
          "description": "Absolute path to target workflow"
        }
      }
    },
    {
      "name": "weaverExecuteTarget",
      "description": "Run the target workflow via the flow-weaver executor with an AI agent channel.",
      "file": "dist/node-types/execute-target.js",
      "functionName": "weaverExecuteTarget",
      "isAsync": true,
      "inputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory"
        },
        "config": {
          "dataType": "string",
          "description": "Config (JSON)"
        },
        "providerType": {
          "dataType": "string",
          "description": "Provider type"
        },
        "providerInfo": {
          "dataType": "string",
          "description": "Provider info (JSON)"
        },
        "targetPath": {
          "dataType": "string",
          "description": "Absolute path to target workflow"
        }
      },
      "outputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory (pass-through)"
        },
        "config": {
          "dataType": "string",
          "description": "Config (pass-through)"
        },
        "targetPath": {
          "dataType": "string",
          "description": "Target path (pass-through)"
        },
        "resultJson": {
          "dataType": "string",
          "description": "Workflow execution result (JSON)"
        }
      }
    },
    {
      "name": "weaverSendNotify",
      "description": "Send webhook/Discord/Slack notifications based on config.",
      "file": "dist/node-types/send-notify.js",
      "functionName": "weaverSendNotify",
      "isAsync": false,
      "inputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory"
        },
        "config": {
          "dataType": "string",
          "description": "Config (JSON)"
        },
        "targetPath": {
          "dataType": "string",
          "description": "Target path"
        },
        "resultJson": {
          "dataType": "string",
          "description": "Result (JSON)"
        }
      },
      "outputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory (pass-through)"
        },
        "targetPath": {
          "dataType": "string",
          "description": "Target path (pass-through)"
        },
        "resultJson": {
          "dataType": "string",
          "description": "Result (pass-through)"
        }
      }
    },
    {
      "name": "weaverReport",
      "description": "Format the result summary, suitable for display or further processing.",
      "file": "dist/node-types/report.js",
      "functionName": "weaverReport",
      "isAsync": false,
      "inputs": {
        "projectDir": {
          "dataType": "string",
          "description": "Project root directory"
        },
        "targetPath": {
          "dataType": "string",
          "description": "Target workflow path"
        },
        "resultJson": {
          "dataType": "string",
          "description": "Result (JSON)"
        }
      },
      "outputs": {
        "summary": {
          "dataType": "string",
          "description": "Summary string"
        }
      }
    },
    {
      "name": "weaverReceiveTask",
      "description": "Receive a task from CLI args, MCP, or the task queue.",
      "file": "dist/node-types/receive-task.js",
      "functionName": "weaverReceiveTask",
      "isAsync": true,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info (JSON)" },
        "taskJson": { "dataType": "string", "description": "Pre-supplied task (JSON)", "optional": true }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "taskJson": { "dataType": "string", "description": "Parsed task (JSON)" },
        "hasTask": { "dataType": "boolean", "description": "Whether a task was found" }
      }
    },
    {
      "name": "weaverRouteTask",
      "description": "Route task by mode: actionable (success) or read-only (failure).",
      "file": "dist/node-types/route-task.js",
      "functionName": "weaverRouteTask",
      "isAsync": false,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" }
      }
    },
    {
      "name": "weaverReadWorkflow",
      "description": "Read and analyze a workflow file with diagram.",
      "file": "dist/node-types/read-workflow.js",
      "functionName": "weaverReadWorkflow",
      "isAsync": false,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" },
        "resultJson": { "dataType": "string", "description": "Workflow description and diagram (JSON)" },
        "filesModified": { "dataType": "string", "description": "Files modified (empty, JSON)" }
      }
    },
    {
      "name": "weaverBuildContext",
      "description": "Build the AI knowledge bundle from flow-weaver context.",
      "file": "dist/node-types/build-context.js",
      "functionName": "weaverBuildContext",
      "isAsync": false,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" },
        "contextBundle": { "dataType": "string", "description": "Knowledge bundle (markdown)" }
      }
    },
    {
      "name": "weaverPlanTask",
      "description": "Send task + context to AI provider and get execution plan.",
      "file": "dist/node-types/plan-task.js",
      "functionName": "weaverPlanTask",
      "isAsync": true,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" },
        "contextBundle": { "dataType": "string", "description": "Knowledge bundle" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" },
        "planJson": { "dataType": "string", "description": "Execution plan (JSON)" }
      }
    },
    {
      "name": "weaverApprovalGate",
      "description": "Present plan for user approval with auto-approve support.",
      "file": "dist/node-types/approval-gate.js",
      "functionName": "weaverApprovalGate",
      "isAsync": true,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info" },
        "planJson": { "dataType": "string", "description": "Plan (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "planJson": { "dataType": "string", "description": "Plan (pass-through)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" },
        "rejectionReason": { "dataType": "string", "description": "Rejection reason (on failure)" }
      }
    },
    {
      "name": "weaverAbortTask",
      "description": "Handle plan rejection and format abort result.",
      "file": "dist/node-types/abort-task.js",
      "functionName": "weaverAbortTask",
      "isAsync": false,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" },
        "rejectionReason": { "dataType": "string", "description": "Rejection reason" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" },
        "resultJson": { "dataType": "string", "description": "Abort result (JSON)" },
        "filesModified": { "dataType": "string", "description": "Files modified (empty, JSON)" }
      }
    },
    {
      "name": "weaverExecValidateRetry",
      "description": "Execute-validate-fix retry loop (up to 3 attempts).",
      "file": "dist/node-types/exec-validate-retry.js",
      "functionName": "weaverExecValidateRetry",
      "isAsync": true,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info (JSON)" },
        "planJson": { "dataType": "string", "description": "Execution plan (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "resultJson": { "dataType": "string", "description": "Final execution result (JSON)" },
        "validationResultJson": { "dataType": "string", "description": "Final validation result (JSON)" },
        "filesModified": { "dataType": "string", "description": "All modified files (JSON array)" },
        "allValid": { "dataType": "boolean", "description": "Whether all files are valid" }
      }
    },
    {
      "name": "weaverExecutePlan",
      "description": "Execute plan steps via the flow-weaver CLI.",
      "file": "dist/node-types/execute-plan.js",
      "functionName": "weaverExecutePlan",
      "isAsync": true,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info" },
        "planJson": { "dataType": "string", "description": "Plan (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "executionResultJson": { "dataType": "string", "description": "Execution result (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" },
        "filesModified": { "dataType": "string", "description": "Files modified (JSON array)" }
      }
    },
    {
      "name": "weaverValidateResult",
      "description": "Validate modified files using flow-weaver validate.",
      "file": "dist/node-types/validate-result.js",
      "functionName": "weaverValidateResult",
      "isAsync": false,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info" },
        "executionResultJson": { "dataType": "string", "description": "Execution result (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" },
        "filesModified": { "dataType": "string", "description": "Files modified (JSON array)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "validationResultJson": { "dataType": "string", "description": "Validation results (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" },
        "allValid": { "dataType": "boolean", "description": "Whether all files passed validation" }
      }
    },
    {
      "name": "weaverFixErrors",
      "description": "Send validation errors to AI for a repair plan.",
      "file": "dist/node-types/fix-errors.js",
      "functionName": "weaverFixErrors",
      "isAsync": true,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "config": { "dataType": "string", "description": "Config (JSON)" },
        "providerType": { "dataType": "string", "description": "Provider type" },
        "providerInfo": { "dataType": "string", "description": "Provider info (JSON)" },
        "validationResultJson": { "dataType": "string", "description": "Validation results (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "config": { "dataType": "string", "description": "Config (pass-through)" },
        "providerType": { "dataType": "string", "description": "Provider type (pass-through)" },
        "providerInfo": { "dataType": "string", "description": "Provider info (pass-through)" },
        "fixPlanJson": { "dataType": "string", "description": "Fix plan (JSON)" },
        "taskJson": { "dataType": "string", "description": "Task (pass-through)" }
      }
    },
    {
      "name": "weaverGitOps",
      "description": "Git operations: stage, commit, branch on modified files.",
      "file": "dist/node-types/git-ops.js",
      "functionName": "weaverGitOps",
      "isAsync": false,
      "inputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory" },
        "filesModified": { "dataType": "string", "description": "Files modified (JSON array)" },
        "config": { "dataType": "string", "description": "Config (JSON)" }
      },
      "outputs": {
        "projectDir": { "dataType": "string", "description": "Project root directory (pass-through)" },
        "gitResultJson": { "dataType": "string", "description": "Git operation result (JSON)" }
      }
    },
    {
      "name": "weaverBotReport",
      "description": "Generate final bot report from any execution path.",
      "file": "dist/node-types/bot-report.js",
      "functionName": "weaverBotReport",
      "isAsync": false,
      "inputs": {
        "readResult": { "dataType": "string", "description": "From read-only path (JSON)", "optional": true },
        "mainResult": { "dataType": "string", "description": "From main execution path (JSON)", "optional": true },
        "abortResult": { "dataType": "string", "description": "From abort path (JSON)", "optional": true },
        "taskJson": { "dataType": "string", "description": "Task (JSON)" },
        "filesModified": { "dataType": "string", "description": "Files modified (JSON array)", "optional": true },
        "gitResultJson": { "dataType": "string", "description": "Git result (JSON)", "optional": true }
      },
      "outputs": {
        "summary": { "dataType": "string", "description": "Summary text" },
        "reportJson": { "dataType": "string", "description": "Full report (JSON)" }
      }
    }
  ],
  "workflows": [],
  "patterns": [],
  "cliEntrypoint": "dist/cli-bridge.js",
  "cliCommands": [
    {
      "name": "run",
      "description": "Run a workflow file",
      "usage": "<file>"
    },
    {
      "name": "history",
      "description": "List recent runs",
      "usage": "[id]"
    },
    {
      "name": "costs",
      "description": "Show cost summary"
    },
    {
      "name": "providers",
      "description": "List available providers"
    },
    {
      "name": "watch",
      "description": "Watch file, re-run on change",
      "usage": "<file>"
    },
    {
      "name": "cron",
      "description": "Run on cron schedule",
      "usage": "<schedule> <file>"
    },
    {
      "name": "pipeline",
      "description": "Run multi-stage pipeline",
      "usage": "<config.json>"
    },
    {
      "name": "dashboard",
      "description": "Start live dashboard",
      "usage": "[file]"
    },
    {
      "name": "eject",
      "description": "Eject managed workflow for customization"
    },
    {
      "name": "bot",
      "description": "Run the autonomous bot with a task",
      "usage": "<task>"
    },
    {
      "name": "session",
      "description": "Start interactive bot session"
    },
    {
      "name": "steer",
      "description": "Send steering command to running bot",
      "usage": "<pause|resume|cancel|redirect|queue> [payload]"
    },
    {
      "name": "queue",
      "description": "Manage bot task queue",
      "usage": "<add|list|clear|remove> [task|id]"
    }
  ],
  "mcpEntrypoint": "dist/mcp-tools.js",
  "mcpTools": [
    {
      "name": "fw_weaver_run",
      "description": "Execute a workflow with the AI runner"
    },
    {
      "name": "fw_weaver_history",
      "description": "Query run history"
    },
    {
      "name": "fw_weaver_costs",
      "description": "Get cost summary"
    },
    {
      "name": "fw_weaver_providers",
      "description": "List available providers"
    },
    {
      "name": "fw_weaver_bot",
      "description": "Run the autonomous bot with a task"
    },
    {
      "name": "fw_weaver_steer",
      "description": "Send steering command to running bot"
    },
    {
      "name": "fw_weaver_queue",
      "description": "Manage bot task queue"
    },
    {
      "name": "fw_weaver_status",
      "description": "Get bot session status"
    }
  ],
  "initContributions": {
    "useCase": {
      "id": "ai-runner",
      "name": "AI Workflow Runner",
      "description": "Autonomous workflow execution with AI providers and notifications"
    },
    "templates": [
      "weaver",
      "weaver-bot"
    ]
  },
  "docs": [
    {
      "slug": "weaver-config",
      "name": "Weaver Configuration",
      "description": "Configuration reference for .weaver.json and autonomous workflow execution",
      "keywords": [
        "weaver",
        "config",
        "provider",
        "notifications",
        "autonomous"
      ],
      "presets": [
        "automation"
      ],
      "file": "dist/docs/weaver-config.md"
    }
  ]
}
