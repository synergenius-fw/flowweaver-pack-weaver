      "inputs": {
        "ctx": {
          "dataType": "string",
          "description": "Weaver context (JSON)"
        }
      },
      "outputs": {
        "ctx": {
          "dataType": "string",
          "description": "Weaver context with resultJson (JSON)"
        }
      }
